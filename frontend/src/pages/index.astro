---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import StatsGrid from '../components/StatsGrid.astro';
import FilterBar from '../components/FilterBar.astro';
import SkillTags from '../components/SkillTags.astro';
import JobTable from '../components/JobTable.astro';
import Insights from '../components/Insights.astro';
import TaxCalculator from '../components/TaxCalculator.astro';
import Methodology from '../components/Methodology.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout>
  <Header />

  <div id="loading" class="flex items-center justify-center py-20">
    <div class="text-center">
      <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-orange-500 mx-auto"></div>
      <p class="text-neutral-500 mt-3 text-sm">Loading jobs...</p>
    </div>
  </div>

  <main id="content" class="hidden">
    <div class="max-w-6xl mx-auto px-4 pt-3">
      <StatsGrid />
      <Insights />
    </div>
    <FilterBar />
    <div class="max-w-6xl mx-auto px-4">
      <SkillTags />
      <JobTable />
      <TaxCalculator />
      <Methodology />
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ base }}>
// ==================================================================
var INDEX, ALL_JOBS = [], FILTERED = [], PAGE = 1, PER_PAGE = 20;
var SORT_KEY = 'relevance', SORT_ASC = false, charts = {};
var DB = base + (base.endsWith('/') ? '' : '/') + 'data/';

// Skill tag colors (soft pastels like Mexico scraper)
var TAG_COLORS = [
  {bg:'#fef2f2',text:'#dc2626'},{bg:'#fff7ed',text:'#ea580c'},{bg:'#fefce8',text:'#ca8a04'},
  {bg:'#f0fdf4',text:'#16a34a'},{bg:'#eff6ff',text:'#2563eb'},{bg:'#faf5ff',text:'#9333ea'},
  {bg:'#fdf2f8',text:'#db2777'},{bg:'#f0fdfa',text:'#0d9488'},{bg:'#fef9c3',text:'#a16207'},
  {bg:'#e0e7ff',text:'#4f46e5'},{bg:'#ffe4e6',text:'#e11d48'},{bg:'#dcfce7',text:'#15803d'},
  {bg:'#dbeafe',text:'#1d4ed8'},{bg:'#f3e8ff',text:'#7c3aed'},{bg:'#fce7f3',text:'#be185d'},
];

// ==================================================================
async function init() {
  try {
    INDEX = await (await fetch(DB + 'index.json')).json();
    var sel = document.getElementById('categorySelect');
    INDEX.categories.forEach(function(c) {
      var o = document.createElement('option'); o.value = c; o.textContent = c;
      sel.appendChild(o);
    });
    if (INDEX.data && INDEX.data.length > 0) { await search(); }
    else { showErr('No data. Run generate_data.py first.'); }
  } catch(e) { showErr('Failed to load data.'); }
}

function showErr(m) {
  document.getElementById('loading').innerHTML = '<p class="text-red-400 text-center py-20 text-sm">'+m+'</p>';
}

// ==================================================================
async function search() {
  var cat = document.getElementById('categorySelect').value;
  document.getElementById('loading').style.display = 'flex';
  document.getElementById('content').classList.add('hidden');

  var entries = INDEX.data;
  if (cat) entries = entries.filter(function(d){return d.query===cat;});
  if (!entries.length) { alert('No data for this category.'); done(); return; }

  ALL_JOBS = [];
  var withSal = 0, salBrackets = {};

  for (var i = 0; i < Math.min(entries.length, 30); i++) {
    try {
      var d = await (await fetch(DB + entries[i].file)).json();
      ALL_JOBS = ALL_JOBS.concat(d.jobs || []);
      withSal += d.stats ? d.stats.with_salary || 0 : 0;
      if (d.charts && d.charts.salary_brackets) {
        for (var k in d.charts.salary_brackets) {
          salBrackets[k] = (salBrackets[k]||0) + d.charts.salary_brackets[k];
        }
      }
    } catch(e) {}
  }

  // Dedup by URL
  var seen = {}, uniq = [];
  ALL_JOBS.forEach(function(j) {
    var u = (j.url||'').toLowerCase().replace(/\/$/,'');
    if (u && seen[u]) return; if (u) seen[u] = true; uniq.push(j);
  });
  ALL_JOBS = uniq;

  // Stats
  var n = ALL_JOBS.length;
  var comps = {}; ALL_JOBS.forEach(function(j){comps[j.company]=1;});
  var ttps = ALL_JOBS.filter(function(j){return j.ttps;}).length;
  var sals = ALL_JOBS.filter(function(j){return j.salary_num>0;}).map(function(j){return j.salary_num;}).sort(function(a,b){return a-b;});
  var medSal = sals.length ? sals[Math.floor(sals.length/2)] : 0;
  var salPct = n > 0 ? Math.round((withSal/n)*100) : 0;

  document.getElementById('statJobs').textContent = n.toLocaleString();
  document.getElementById('statCompanies').textContent = Object.keys(comps).length.toLocaleString();
  document.getElementById('statTTPS').textContent = ttps.toLocaleString();

  // Sources count
  var srcSet = {};
  ALL_JOBS.forEach(function(j){ srcSet[j.source] = 1; });
  var srcEl = document.getElementById('statSources');
  if (srcEl) srcEl.textContent = Object.keys(srcSet).length;

  // Median from real + estimated salary_num
  var allSalNums = ALL_JOBS.filter(function(j){return j.salary_num>0;}).map(function(j){return j.salary_num;}).sort(function(a,b){return a-b;});
  var estCount = ALL_JOBS.filter(function(j){return j.salary_est;}).length;
  medSal = allSalNums.length ? allSalNums[Math.floor(allSalNums.length/2)] : 0;

  if (medSal > 0) {
    document.getElementById('statSalary').textContent = 'HK$' + medSal.toLocaleString();
  } else {
    document.getElementById('statSalary').textContent = 'N/A';
  }

  // Skill tags
  renderSkillTags();

  // Charts
  renderCharts(salBrackets);

  // Table
  FILTERED = ALL_JOBS.slice(); PAGE = 1; applyFilters();

  done();
}

function done() {
  document.getElementById('loading').style.display = 'none';
  document.getElementById('content').classList.remove('hidden');
}

// ==================================================================
// SKILL TAGS (colorful pills like Mexico scraper)
// ==================================================================
function renderSkillTags() {
  var counts = {};
  ALL_JOBS.forEach(function(j){ (j.skills||[]).forEach(function(s){ counts[s]=(counts[s]||0)+1; }); });
  var skills = Object.entries(counts).sort(function(a,b){return b[1]-a[1];}).slice(0,15);

  var wrap = document.getElementById('skillTagsWrap');
  var sec = document.getElementById('skillTagsSection');

  if (skills.length < 3) { sec.classList.add('hidden'); return; }
  sec.classList.remove('hidden');

  wrap.innerHTML = skills.map(function(s, i) {
    var c = TAG_COLORS[i % TAG_COLORS.length];
    return '<span style="background:'+c.bg+';color:'+c.text+'" class="px-2.5 py-1 rounded-full text-xs font-medium">'
      + esc(s[0]) + ' <span class="opacity-70">' + s[1] + '</span></span>';
  }).join('');
}

// ==================================================================
// CHARTS (orange accent, only render if data exists)
// ==================================================================
function renderCharts(salBrackets) {
  var ax = '#525252', grid = '#1a1a1a';
  // Salary bracket colors (like Mexico: each bracket a different color)
  var bracketColors = ['#ea580c','#16a34a','#f97316','#2563eb','#7c3aed','#dc2626'];

  // --- Salary Brackets (horizontal bars like Mexico "Donde esta el dinero?") ---
  if (charts.salary) charts.salary.destroy();
  var salSec = document.getElementById('salarySection');
  var salLabels = Object.keys(salBrackets||{});
  var salValues = Object.values(salBrackets||{});
  var salTotal = salValues.reduce(function(a,b){return a+b;},0);

  if (salTotal > 0) {
    salSec.style.display = '';
    charts.salary = new Chart(document.getElementById('salaryChart'), {
      type: 'bar',
      data: {
        labels: salLabels,
        datasets: [{
          data: salValues,
          backgroundColor: bracketColors.slice(0, salLabels.length),
          borderRadius: 3,
        }]
      },
      options: {
        indexAxis: 'y', responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                var pct = salTotal > 0 ? Math.round(ctx.raw/salTotal*100) : 0;
                return ctx.raw + ' (' + pct + '%)';
              }
            }
          }
        },
        scales: {
          x: { ticks:{color:ax,font:{size:10}}, grid:{color:grid} },
          y: { ticks:{color:'#d4d4d4',font:{size:11}}, grid:{display:false} },
        },
      },
    });
  } else { salSec.style.display = 'none'; }

  // --- Salary by Seniority ---
  if (charts.seniority) charts.seniority.destroy();
  var senSec = document.getElementById('senioritySection');
  var senSal = {};
  ALL_JOBS.forEach(function(j) {
    if (j.salary_num > 0 && j.seniority) {
      if (!senSal[j.seniority]) senSal[j.seniority] = [];
      senSal[j.seniority].push(j.salary_num);
    }
  });
  var levels = Object.entries(senSal)
    .map(function(e){var s=e[1].sort(function(a,b){return a-b;}); return {l:e[0],m:s[Math.floor(s.length/2)],n:s.length};})
    .filter(function(d){return d.n>=2;})
    .sort(function(a,b){return b.m-a.m;});

  if (levels.length >= 2) {
    senSec.style.display = '';
    charts.seniority = new Chart(document.getElementById('seniorityChart'), {
      type: 'bar',
      data: {
        labels: levels.map(function(d){return d.l;}),
        datasets: [{ data: levels.map(function(d){return d.m;}), backgroundColor: '#f97316', borderRadius: 3 }]
      },
      options: {
        responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
        scales: {
          x:{ticks:{color:ax,font:{size:10}},grid:{display:false}},
          y:{ticks:{color:ax,font:{size:10},callback:function(v){return 'HK$'+v.toLocaleString();}},grid:{color:grid}},
        },
      },
    });
  } else { senSec.style.display = 'none'; }

  // --- Top Employers (horizontal bars, green like Mexico) ---
  if (charts.employers) charts.employers.destroy();
  var empSec = document.getElementById('employersSection');
  var compCounts = {};
  ALL_JOBS.forEach(function(j){if(j.company&&j.company!=='Confidential')compCounts[j.company]=(compCounts[j.company]||0)+1;});
  var emps = Object.entries(compCounts).sort(function(a,b){return b[1]-a[1];}).slice(0,8);

  if (emps.length >= 3) {
    empSec.style.display = '';
    charts.employers = new Chart(document.getElementById('employersChart'), {
      type: 'bar',
      data: {
        labels: emps.map(function(e){return e[0].length>35?e[0].slice(0,33)+'...':e[0];}),
        datasets: [{ data: emps.map(function(e){return e[1];}), backgroundColor: '#16a34a', borderRadius: 3 }]
      },
      options: {
        indexAxis:'y', responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
        scales: {
          x:{ticks:{color:ax,font:{size:10}},grid:{color:grid}},
          y:{ticks:{color:'#d4d4d4',font:{size:10}},grid:{display:false}},
        },
      },
    });
  } else { empSec.style.display = 'none'; }

  // Empty state
  var anyChart = salTotal > 0 || levels.length >= 2 || emps.length >= 3;
  document.getElementById('insightsEmpty').classList.toggle('hidden', anyChart);
}

// ==================================================================
// TABLE
// ==================================================================
function applyFilters() {
  var q = document.getElementById('searchInput').value.toLowerCase();
  var sen = document.getElementById('seniorityFilter').value;
  var wm = document.getElementById('workModeFilter').value;
  var src = document.getElementById('sourceFilter').value;
  var ttps = document.getElementById('ttpsFilter').checked;

  FILTERED = ALL_JOBS.filter(function(j) {
    if (q && j.title.toLowerCase().indexOf(q)===-1 && j.company.toLowerCase().indexOf(q)===-1) return false;
    if (sen && j.seniority!==sen) return false;
    if (wm && j.work_mode!==wm) return false;
    if (src && j.source!==src) return false;
    if (ttps && !j.ttps) return false;
    return true;
  });

  FILTERED.sort(function(a,b) {
    var va=a[SORT_KEY]||'', vb=b[SORT_KEY]||'';
    if (typeof va==='number'&&typeof vb==='number') return SORT_ASC?va-vb:vb-va;
    return SORT_ASC?String(va).localeCompare(String(vb)):String(vb).localeCompare(String(va));
  });

  renderTable();
}

var VIEW_MODE = 'table'; // 'table' or 'cards'

function renderTable() {
  var start = (PAGE-1)*PER_PAGE;
  var page = FILTERED.slice(start, start+PER_PAGE);
  var totalPages = Math.max(1, Math.ceil(FILTERED.length/PER_PAGE));

  // Table view
  document.getElementById('jobTableBody').innerHTML = page.map(function(j) {
    var mc = j.match>=50?'#f97316':j.match>=25?'#ea580c':'#333';
    var fitClass = (j.relevance||0)>=60?'fit-high':(j.relevance||0)>=30?'fit-med':'fit-low';
    var fitTip = (j.relevance||0)>=60?'Strong category fit':'Partial match';
    var salHtml = salaryHtml(j);
    var ttpsB = j.ttps?'<span class="badge badge-ttps ml-1">TTPS</span>':'';
    var srcLabel = {linkedin:'LinkedIn',indeed:'Indeed',google:'Google',jobsdb:'JobsDB',lever:'Lever',greenhouse:'Greenhouse'}[j.source]||j.source;
    return '<tr class="job-row border-b border-neutral-800/30">'
      +'<td class="py-3 pr-2 text-center" title="'+fitTip+'"><span class="fit-dot '+fitClass+'"></span></td>'
      +'<td class="py-3 pr-3"><div class="flex items-center gap-2"><span class="text-xs text-neutral-400 w-7 text-right font-medium">'+j.match+'%</span><div class="match-bar flex-1"><div class="match-bar-fill" style="width:'+j.match+'%;background:'+mc+'"></div></div></div></td>'
      +'<td class="py-3 pr-3"><a href="'+(j.url||'#')+'" target="_blank" rel="noopener" class="text-neutral-200 hover:text-orange-400 font-medium text-sm transition">'+esc(j.title)+'</a>'+ttpsB+'</td>'
      +'<td class="py-3 pr-3 text-neutral-400 text-sm">'+esc(j.company)+'</td>'
      +'<td class="py-3 pr-3 text-sm">'+salHtml+'</td>'
      +'<td class="py-3 pr-3 text-xs text-neutral-500">'+esc(j.seniority||'')+'</td>'
      +'<td class="py-3 pr-3">'+wmPill(j.work_mode)+'</td>'
      +'<td class="py-3"><span class="badge badge-'+j.source+'">'+srcLabel+'</span></td>'
      +'</tr>';
  }).join('');

  // Card view
  document.getElementById('cardView').innerHTML = page.map(function(j) {
    var mc = j.match>=50?'#f97316':j.match>=25?'#ea580c':'#333';
    var ttpsB = j.ttps?'<span class="badge badge-ttps">TTPS</span>':'';
    var srcLabel = {linkedin:'LinkedIn',indeed:'Indeed',google:'Google',jobsdb:'JobsDB',lever:'Lever',greenhouse:'Greenhouse'}[j.source]||j.source;
    var fitClass = (j.relevance||0)>=60?'fit-high':(j.relevance||0)>=30?'fit-med':'fit-low';
    return '<div class="glass job-card p-4">'
      // Row 1: Title + salary
      +'<div class="flex items-start justify-between gap-3 mb-1">'
      +'<a href="'+(j.url||'#')+'" target="_blank" rel="noopener" class="text-sm font-semibold text-white hover:text-orange-400 transition leading-snug flex-1 min-w-0">'+esc(j.title)+'</a>'
      +'<div class="text-right shrink-0">'+salaryHtml(j)+'</div></div>'
      // Row 2: Company
      +'<div class="text-xs text-neutral-400 mb-2.5">'+esc(j.company)+'</div>'
      // Row 3: Match bar
      +'<div class="flex items-center gap-2 mb-2.5"><span class="fit-dot '+fitClass+'"></span><div class="match-bar flex-1"><div class="match-bar-fill" style="width:'+j.match+'%;background:'+mc+'"></div></div>'
      +'<span class="text-xs text-neutral-400 font-medium w-8 text-right">'+j.match+'%</span></div>'
      // Row 4: Metadata pills + Apply
      +'<div class="flex items-center justify-between">'
      +'<div class="flex flex-wrap items-center gap-1.5">'
      +wmPill(j.work_mode)
      +(j.seniority?'<span class="inline-block px-2 py-0.5 rounded text-[10px] font-medium bg-neutral-800 text-neutral-400 border border-neutral-700/50">'+esc(j.seniority)+'</span>':'')
      +ttpsB
      +'<span class="badge badge-'+j.source+'">'+srcLabel+'</span></div>'
      +(j.url?'<a href="'+esc(j.url)+'" target="_blank" rel="noopener" class="text-xs text-orange-400 hover:text-orange-300 font-semibold transition whitespace-nowrap">Apply &rarr;</a>':'')
      +'</div></div>';
  }).join('');

  // Show correct view
  document.getElementById('tableView').style.display = VIEW_MODE==='table'?'':'none';
  document.getElementById('cardView').style.display = VIEW_MODE==='cards'?'':'none';

  var showing = FILTERED.length>0?(start+1)+'-'+Math.min(start+PER_PAGE,FILTERED.length):'0';
  document.getElementById('tableInfo').textContent = showing+' of '+FILTERED.length+' jobs';
  document.getElementById('pageInfo').textContent = PAGE+'/'+totalPages;
}

function switchView(mode) {
  VIEW_MODE = mode;
  document.getElementById('viewTable').classList.toggle('active', mode==='table');
  document.getElementById('viewCards').classList.toggle('active', mode==='cards');
  renderTable();
}

function sortTable(key) {
  document.querySelectorAll('.sort-arrow').forEach(function(el){el.textContent='';});
  if (SORT_KEY===key){SORT_ASC=!SORT_ASC;}else{SORT_KEY=key;SORT_ASC=false;}
  var a = document.querySelector('th[data-sort="'+key+'"] .sort-arrow');
  if (a) a.textContent = SORT_ASC?' ↑':' ↓';
  PAGE=1; applyFilters();
}

function esc(s){var d=document.createElement('div');d.textContent=s||'';return d.innerHTML;}

function wmPill(mode) {
  if (mode==='Remote') return '<span class="inline-block px-2 py-0.5 rounded text-[11px] font-semibold wm-remote">Remote</span>';
  if (mode==='Hybrid') return '<span class="inline-block px-2 py-0.5 rounded text-[11px] font-semibold wm-hybrid">Hybrid</span>';
  if (mode==='On-site') return '<span class="inline-block px-2 py-0.5 rounded text-[11px] font-semibold wm-onsite">On-site</span>';
  return '<span class="text-neutral-700 text-[11px]">&mdash;</span>';
}

function salaryHtml(j) {
  // Real salary from listing
  if (j.salary_num > 0 && !j.salary_est) {
    return '<span class="salary-real">'+esc(j.salary)+'</span>';
  }
  // Estimated salary
  if (j.salary_est) {
    var tip = 'Estimated (' + (j.salary_confidence||'') + ' confidence): ' + (j.salary_basis||'');
    var conf = j.salary_confidence==='High'?'text-neutral-300':'text-neutral-400';
    return '<span class="salary-est '+conf+'" title="'+esc(tip)+'">'+esc(j.salary)+' <span class="text-[9px] align-top opacity-50">est</span></span>';
  }
  return '<span class="salary-none">Not disclosed</span>';
}

function downloadExcel() {
  var rows = FILTERED.map(function(j){
    return {'Match%':j.match,Title:j.title,Company:j.company,Salary:j.salary,
      Seniority:j.seniority||'','Work Mode':j.work_mode||'',TTPS:j.ttps?'Yes':'No',
      Skills:(j.skills||[]).join(', '),Source:j.source,URL:j.url};
  });
  var ws=XLSX.utils.json_to_sheet(rows);var wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,ws,'HK Jobs');
  XLSX.writeFile(wb,'hk_jobs_'+new Date().toISOString().slice(0,10)+'.xlsx');
}

// ==================================================================
// EVENTS
// ==================================================================
document.getElementById('searchBtn').addEventListener('click',search);
document.getElementById('searchInput').addEventListener('input',function(){PAGE=1;applyFilters();});
document.getElementById('seniorityFilter').addEventListener('change',function(){PAGE=1;applyFilters();});
document.getElementById('workModeFilter').addEventListener('change',function(){PAGE=1;applyFilters();});
document.getElementById('sourceFilter').addEventListener('change',function(){PAGE=1;applyFilters();});
document.getElementById('ttpsFilter').addEventListener('change',function(){PAGE=1;applyFilters();});
document.getElementById('prevPageBtn').addEventListener('click',function(){if(PAGE>1){PAGE--;renderTable();}});
document.getElementById('nextPageBtn').addEventListener('click',function(){if(PAGE<Math.ceil(FILTERED.length/PER_PAGE)){PAGE++;renderTable();}});
document.getElementById('downloadExcelBtn').addEventListener('click',downloadExcel);
document.getElementById('viewTable').addEventListener('click',function(){switchView('table');});
document.getElementById('viewCards').addEventListener('click',function(){switchView('cards');});
document.querySelectorAll('th[data-sort]').forEach(function(th){th.addEventListener('click',function(){sortTable(th.getAttribute('data-sort'));});});
document.getElementById('categorySelect').addEventListener('keydown',function(e){if(e.key==='Enter')search();});

var initArrow=document.querySelector('th[data-sort="relevance"] .sort-arrow');
if(initArrow) initArrow.textContent=' ↓';

init();
</script>
