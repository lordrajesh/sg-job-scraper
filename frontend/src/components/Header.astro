---
// Header: value proposition + brand + social links
---

<header class="bg-gradient-to-r from-orange-600 via-orange-700 to-orange-800 px-4 py-3.5">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-white/15 flex items-center justify-center text-white font-bold text-sm shrink-0">RR</div>
      <div>
        <h1 class="text-base sm:text-lg font-bold text-white tracking-tight leading-tight">Singapore Job Market Intelligence</h1>
        <div class="text-orange-200/70 text-[10px] hidden sm:flex items-center gap-1.5">
          <span>1,000+ listings</span>
          <span class="opacity-40">|</span>
          <span>7 sources</span>
          <span class="opacity-40">|</span>
          <span>Salary estimates</span>
          <span class="opacity-40">|</span>
          <span>Updated daily</span>
        </div>
      </div>
      <div class="hidden sm:flex items-center gap-1.5 ml-2">
        <a href="https://linkedin.com/in/rajesh-rajagopalan-72b696b9" target="_blank" rel="noopener"
          class="w-7 h-7 rounded-md bg-white/10 hover:bg-white/20 flex items-center justify-center transition" title="LinkedIn — Rajesh Rajagopalan">
          <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <select id="categorySelect" class="input text-sm flex-1 sm:w-56">
        <option value="">All Categories</option>
      </select>
      <button id="searchBtn" class="bg-white text-orange-700 font-semibold px-5 py-2 rounded-lg text-sm hover:bg-orange-50 transition whitespace-nowrap shadow-sm">
        Search
      </button>
    </div>
  </div>
</header>
