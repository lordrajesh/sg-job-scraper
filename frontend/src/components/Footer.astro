---
// Builder identity footer — prominent, recruiter-facing
---

<!-- Builder banner -->
<div class="max-w-6xl mx-auto px-4 mb-4">
  <div class="glass p-4">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="text-sm font-semibold text-white">Built by Irmin Corona</div>
        <div class="text-xs text-neutral-400 mt-0.5">Senior Data Analyst &middot; 7 years at Microsoft &amp; Stellantis &middot; TTPS Visa Holder</div>
      </div>
      <div class="flex items-center gap-2">
        <a href="https://linkedin.com/in/irmin-corona" target="_blank" rel="noopener"
          class="px-3 py-1.5 rounded-md bg-[#0a66c2] text-white text-xs font-medium hover:bg-[#004182] transition">
          LinkedIn
        </a>
        <a href="https://github.com/ircorona/hk-job-scraper" target="_blank" rel="noopener"
          class="px-3 py-1.5 rounded-md bg-neutral-700 text-white text-xs font-medium hover:bg-neutral-600 transition">
          Source Code
        </a>
        <a href="https://climbthesearches.com" target="_blank" rel="noopener"
          class="px-3 py-1.5 rounded-md bg-orange-700 text-white text-xs font-medium hover:bg-orange-600 transition">
          Portfolio
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Minimal copyright -->
<footer class="max-w-6xl mx-auto px-4 py-4 text-center text-[11px] text-neutral-600">
  <p>Data from LinkedIn, Indeed, Google Jobs, JobsDB, Lever &amp; Greenhouse &nbsp;|&nbsp; Salaries estimated from JobsDB &amp; market benchmarks (March 2026)</p>
  <p class="mt-1">&copy; {new Date().getFullYear()} <a href="https://climbthesearches.com/" class="hover:text-neutral-400 transition">Climb The Searches</a></p>
</footer>
